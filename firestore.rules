rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Specific rule: Users can only read and write their own documents
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Fallback rule: Deny all other read/write requests by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
